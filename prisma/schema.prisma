// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Transactional Tables (provided by user) ---

model FiscalYear {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  periods   BudgetCycle[]

  @@map("fiscal_years")
}

model OrgUnit {
  id        String    @id @default(uuid()) @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  code      String    @unique @db.VarChar(50)
  name      String    @db.VarChar(255)
  type      String    @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  parent    OrgUnit?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  OrgUnit[] @relation("OrgHierarchy")
  assets    Asset[]

  @@map("org_units")
}

model BudgetCycle {
  id           String     @id @default(uuid()) @db.Uuid
  fiscalYearId String     @map("fiscal_year_id") @db.Uuid
  name         String     @db.VarChar(255)
  status       String     @db.VarChar(50)
  openedAt     DateTime?  @map("opened_at")
  closedAt     DateTime?  @map("closed_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@map("budget_cycles")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(100)
  title       String   @db.VarChar(500)
  description String?
  sector      String   @db.VarChar(100)
  status      String   @db.VarChar(50)
  fundingType String   @map("funding_type") @db.VarChar(50)
  county      String?  @db.VarChar(100)
  district    String?  @db.VarChar(100)
  totalCost   Decimal? @map("total_cost") @db.Decimal(18, 2)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model Asset {
  id                String   @id @default(uuid()) @db.Uuid
  assetTag          String   @unique @map("asset_tag") @db.VarChar(100)
  name              String   @db.VarChar(255)
  category          String   @db.VarChar(100)
  acquisitionCost   Decimal? @map("acquisition_cost") @db.Decimal(18, 2)
  acquisitionDate   DateTime? @map("acquisition_date") @db.Date
  status            String   @db.VarChar(50)
  assignedOrgUnitId String?  @map("assigned_org_unit_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  orgUnit           OrgUnit? @relation(fields: [assignedOrgUnitId], references: [id])

  @@map("assets")
}

model SOE {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @unique @db.VarChar(50)
  name           String   @db.VarChar(255)
  sector         String?  @db.VarChar(100)
  ownershipType  String?  @map("ownership_type") @db.VarChar(100)
  oversightUnit  String?  @map("oversight_unit") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("soes")
}

// --- Warehouse Dimension Tables ---

model DimDate {
  dateId    Int      @id @map("date_id")
  date      DateTime @db.Date
  year      Int
  quarter   Int
  month     Int
  day       Int
  isWeekend Boolean  @map("is_weekend")
  
  @@map("dim_date")
}

model DimOrgUnit {
  orgUnitId Int    @id @map("org_unit_id")
  code      String @db.VarChar(50)
  name      String @db.VarChar(255)
  type      String @db.VarChar(50)
  parentName String? @map("parent_name")
  
  @@map("dim_org_unit")
}

// --- Warehouse Fact Tables (Aggregates for Dashboards) ---

model FactAidDisbursement {
  id             String  @id @default(uuid()) @db.Uuid
  dateId         Int     @map("date_id")
  orgUnitId      Int     @map("org_unit_id")
  donor          String
  amountDisbursed Decimal @map("amount_disbursed") @db.Decimal(18, 2)
  amountCommitted Decimal @map("amount_committed") @db.Decimal(18, 2)
  
  @@map("fact_aid_disbursement")
}

model FactNgoCompliance {
  id             String  @id @default(uuid()) @db.Uuid
  ngoId          String  @map("ngo_id")
  sector         String
  complianceScore Int    @map("compliance_score")
  status         String
  lastAuditDate  DateTime @map("last_audit_date") @db.Date
  
  @@map("fact_ngo_compliance")
}
